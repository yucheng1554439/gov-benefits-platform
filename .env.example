# Government Benefits Platform — Environment Variables
# Copy to .env for local development or reference for production deployment.

# ── API Server ──────────────────────────────────────────────────────────────
PORT=8080
ENVIRONMENT=development

# ── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://govbenefits:govbenefits@localhost:5432/govbenefits?sslmode=disable

# ── Redis (job queue + cache) ───────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Authentication ──────────────────────────────────────────────────────────
# REQUIRED in production — generate with: openssl rand -hex 32
JWT_SECRET=change-me-in-production
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800

# ── Object Storage ──────────────────────────────────────────────────────────
# Use "local" for filesystem storage or "s3" for MinIO/S3-compatible storage
STORAGE_DRIVER=s3
LOCAL_STORAGE_PATH=./storage
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=govbenefits
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1

# ── CORS ────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000
# Production (Render):
# CORS_ORIGIN=https://gov-benefits-platform.vercel.app

# ── Email (optional — Mailhog in dev) ───────────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025

# ── Frontend ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1
# Production (Vercel):
# NEXT_PUBLIC_API_URL=https://gov-benefits-platform.onrender.com/api/v1
